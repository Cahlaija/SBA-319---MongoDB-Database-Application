db.jobs.createIndex({company:1})

db.jobs.createIndex({status:1})

db.jobs.createIndex({
  userId:1,
  status:1
})

db.createCollection("jobs", {
 validator: {
   $jsonSchema:{
     bsonType:"object",
     required:[
       "company",
       "position",
       "status"
     ],
     properties:{
       company:{
         bsonType:"string"
       },
       position:{
         bsonType:"string"
       },
       status:{
         enum:[
           "Applied",
           "Interview",
           "Rejected",
           "Offer"
         ]
       }
     }
   }
 }
})